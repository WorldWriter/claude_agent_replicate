# ==================================
# LLM Provider 配置
# ==================================
# 选择: kimi | gemini | claude | minimax (默认 kimi)
LLM_PROVIDER=kimi

# 通用模型名称 (可选，覆盖 Provider 默认值)
# LLM_MODEL=

# ==================================
# Kimi (Moonshot) 配置
# ==================================
MOONSHOT_API_KEY=sk-your-kimi-api-key-here
# KIMI_API_BASE=https://api.moonshot.ai/v1

# ==================================
# Minimax 配置
# ==================================
# MINIMAX_API_KEY=sk-your-minimax-api-key-here
# MINIMAX_API_BASE=https://api.minimax.chat/v1
# MINIMAX_MODEL=abab6.5-chat

# ==================================
# Gemini 配置
# ==================================
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/

# ==================================
# 模型名称参考
# ==================================
# Gemini: gemini-2.0-flash | gemini-2.5-flash | gemini-2.5-pro
# Kimi:   kimi-k2-turbo-preview | kimi-k2.5-thinking-preview

# ==================================
# Claude (Anthropic) 配置
# ==================================
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# Claude models: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001

# ==================================
# Data & Logging Configuration
# ==================================
DATA_DIR=datasets
OUTPUT_DIR=results
LOG_LEVEL=INFO
